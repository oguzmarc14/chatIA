PORT=3000
NODE_ENV=development

# Elige una frase privada para verificar el webhook en Meta.
WEBHOOK_VERIFY_TOKEN=cambia-esta-frase-privada

# Credenciales de WhatsApp Cloud API (no subas el archivo .env a GitHub).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
META_APP_SECRET=

# Usa la versión activa que muestre tu aplicación en Meta Developers.
META_GRAPH_API_VERSION=v23.0

